# API Gateway URL (Production)
VITE_API_URL=https://api.biostock.com

# Environment
VITE_ENV=production

# Keycloak Configuration (Production)
VITE_KEYCLOAK_URL=https://api.biostock.com/auth
VITE_KEYCLOAK_REALM=biostock
VITE_KEYCLOAK_CLIENT_ID=biostock-frontend

# Auth Provider
VITE_AUTH_PROVIDER=keycloak
